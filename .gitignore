# --- Android / Gradle build outputs (reproducible) ---
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/
*.iml
*.keystore
*.jks

# --- Built APKs (regenerated by the build; kept in the working tree, not tracked) ---
*.apk

# --- Python ---
__pycache__/
*.pyc
.venv/
tools/.venv/

# --- Arduino / firmware build caches (arduino-cli builds out-of-tree, but just in case) ---
firmware/build/
firmware-ble-test/build/
**/*.bin
**/*.elf

# --- Logs / scratch ---
*.log

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini
