<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:padding="20dp">

    <!-- ===================== Connection status row ===================== -->

    <TextView
        android:id="@+id/labelConnection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_connection"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/wdl_on_surface_muted"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- App version (set at runtime from packageInfo). -->
    <TextView
        android:id="@+id/textVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/wdl_on_surface_muted"
        android:textSize="11sp"
        tools:text="v0.6.0"
        app:layout_constraintTop_toTopOf="@id/settingsButton"
        app:layout_constraintBottom_toBottomOf="@id/settingsButton"
        app:layout_constraintEnd_toStartOf="@id/settingsButton"
        android:layout_marginEnd="8dp" />

    <!-- Gear: opens the BLE console / diagnostics screen. -->
    <ImageButton
        android:id="@+id/settingsButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_settings"
        android:contentDescription="@string/console_open"
        app:tint="@color/wdl_gold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/statusDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/status_dot"
        app:layout_constraintTop_toBottomOf="@id/labelConnection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/textStatus" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="2dp"
        android:text="@string/status_disconnected"
        android:textColor="@color/wdl_on_surface"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/labelConnection"
        app:layout_constraintStart_toEndOf="@id/statusDot"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===================== Live partial transcript ===================== -->

    <TextView
        android:id="@+id/labelPartial"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/label_partial"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/wdl_on_surface_muted"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/textStatus"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:id="@+id/partialScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:background="@color/wdl_surface"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/labelPartial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/labelLastSent"
        app:layout_constraintVertical_weight="2">

        <TextView
            android:id="@+id/textPartial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_dash"
            android:textColor="@color/wdl_on_surface"
            android:textSize="18sp" />
    </ScrollView>

    <!-- ===================== Last sent text ===================== -->

    <TextView
        android:id="@+id/labelLastSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/label_last_sent"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:textColor="@color/wdl_on_surface_muted"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/lastSentScroll" />

    <ScrollView
        android:id="@+id/lastSentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:background="@color/wdl_surface"
        android:padding="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/keyRow"
        app:layout_constraintVertical_weight="1">

        <TextView
            android:id="@+id/textLastSent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_dash"
            android:textColor="@color/wdl_gold"
            android:textSize="16sp" />
    </ScrollView>

    <!-- ===================== Special-key row ===================== -->

    <LinearLayout
        android:id="@+id/keyRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/micButton">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/keyEnter"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/key_enter" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/keyTab"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="@string/key_tab" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/keyBackspace"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/key_backspace" />
    </LinearLayout>

    <!-- ===================== Big mic toggle ===================== -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/micButton"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:layout_marginTop="24dp"
        android:text="@string/mic_start"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="38dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
